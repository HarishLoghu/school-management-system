MONGO_URL = mongodb://127.0.0.1/smsproject

SECRET_KEY = 'secret123key'


# MONGO_URL instructions
#
# Option 1 — Local MongoDB (Community Server + Compass)
# - MongoDB has two parts:
#     1) `mongod` → the actual database server (runs in the background)
#     2) Compass → a GUI to view/edit data
# - Install “MongoDB Community Server” from mongodb.com/try/download/community.
#   This install includes `mongod`. You do NOT install `mongod` separately.
# - Install “MongoDB Compass” from mongodb.com/try/download/compass.
# - Start the MongoDB server:
#     • On Windows/macOS it usually starts automatically as a service.
#     • If not, you can start it manually in a terminal: `mongod`.
# - Open Compass. Use the default connection string:
#     mongodb://127.0.0.1:27017/yourdbname
# - Replace `yourdbname` with any name. That full line becomes your MONGO_URL.

# Option 2 — MongoDB Atlas (Cloud)
# - Create an account at mongodb.com/atlas and make a free cluster.
# - Go to “Database → Connect → Connect your application”.
# - Copy the connection string Atlas gives you:
#     mongodb+srv://<user>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority
# - Replace <user>, <password>, <dbname>.
# - Use that whole string as MONGO_URL.
# - Use this when you want to deploy it to production.

# SECRET_KEY is any random string you choose.
